{
  "name": "openweb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "openweb": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean && node scripts/build-adapters.js",
    "dev": "tsx src/cli.ts",
    "lint": "biome lint src scripts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "playwright": "^1.52.0",
    "yargs": "^18.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.3.0",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
