{
  "name": "@openweb-org/openweb",
  "version": "0.1.5",
  "description": "Let any agent access the web — typed site APIs, auth primitives, one CLI",
  "type": "module",
  "bin": {
    "openweb": "dist/cli.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "agent",
    "web",
    "api",
    "browser",
    "automation",
    "scraping",
    "cdp"
  ],
  "author": "openweb-org contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openweb-org/openweb.git"
  },
  "homepage": "https://github.com/openweb-org/openweb#readme",
  "bugs": {
    "url": "https://github.com/openweb-org/openweb/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean && node scripts/build-adapters.js && node scripts/build-sites.js",
    "dev": "tsx src/cli.ts",
    "lint": "biome lint src scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "tsx tests/integration/runner.ts",
    "pack:check": "node scripts/pack-check.js",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build && pnpm pack:check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "patchright": "^1.59.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.3.0",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.33",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
